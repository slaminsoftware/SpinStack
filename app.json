{
  "expo": {
    "name": "SpinStack",
    "slug": "spinstack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.slaminsoftware.spinstack",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.slaminsoftware.spinstack"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "kotlinVersion": "2.1.21"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4492202957160787~9699181297",
          "iosAppId": "ca-app-pub-4492202957160787~8381871404"
        }
      ],
      "./plugins/withRemoveRecordAudio"
    ],
    "extra": {
      "eas": {
        "projectId": "10cb369b-db1c-4aba-878d-9c52915a8270"
      }
    },
    "owner": "slaminsoftware"
  }
}
